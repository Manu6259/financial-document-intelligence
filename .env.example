# Copy to .env. Runs with a deterministic offline mock if no key is set.
OPENAI_API_KEY=

APP_LLM_MODEL=gpt-4o-mini
# Embeddings are local via Ollama. Make sure `ollama serve` is running and you've
# pulled the model:  ollama pull nomic-embed-text
APP_EMBED_MODEL=nomic-embed-text
APP_OLLAMA_URL=http://localhost:11434

# SEC requires a descriptive User-Agent with contact info on every request.
SEC_USER_AGENT=Your Name your@email.com

# Force the offline mock even if a key is present (fast, free, reproducible)
APP_USE_MOCK=0
